@inject IStringLocalizer<Resource> localizer

<MudText Typo="Typo.h4" Class="my-3">@localizer["DynamicDNSUpdateClient"]</MudText>
    <MudButton Size="Size.Small" Variant="Variant.Filled" Color="Color.Primary" EndIcon="@Icons.Material.Filled.Download"
               Target="_blank" Href="https://api.dnslab.link/Files/setup/win/dnslab.msi">
        @(localizer["DownloadNow"] + "(v1.6.4)")
    </MudButton>
    <MudText Class="my-3 ">@localizer["WinClientMessage"]</MudText>
    <MudAlert Severity="Severity.Info" Dense ContentAlignment="HorizontalAlignment.Start">
     <MudText>
         این اپلیکیشن بصورت متن باز در
         <MudLink Href="https://github.com/AkbarAsghari/DNSLab-WinApplication">این مخزن</MudLink>
         قرار گرفته است تا برنامه نویسان با خیال راحت از آن استفاده نمایند.
     </MudText>
 </MudAlert>
 <MudAlert Severity="Severity.Info" Dense ContentAlignment="HorizontalAlignment.Start">
     <MudText>
         در صورتی که شما سیستم عامل ویندوز ندارید و یا نمیخواهید از اپلیکیشن استفاده نمایید لطفا این
        <MudLink Href="Page/Support/Create-New-Token-For-DNS">مطلب</MudLink>
         را مطالعه بفرمایید.
     </MudText>
 </MudAlert>
