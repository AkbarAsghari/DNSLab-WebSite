@page "/Transaction/Callback"
@inject ITransactionRepository _TransactionRepository

@if (Success == 1)
{
    <MudAlert Severity="Severity.Success" ContentAlignment="HorizontalAlignment.Right">
        <MudText>پرداخت با موفقیت انجام شد</MudText>
        <MudText>شناسه پرداخت : @TrackId</MudText>
            <MudText>با تشکر از حمایت شما از سایت DNSLab</MudText>
        </MudAlert>
}
else
{
    <MudAlert Severity="Severity.Error" ContentAlignment="HorizontalAlignment.Right">
        <MudText>پرداخت با شکست مواجه شد</MudText>
        <MudText>شناسه : @TrackId</MudText>
            <MudText>علت : @Result</MudText>
        </MudAlert>
}
<MudButton StartIcon=@Icons.Material.Filled.Home Variant="Variant.Filled" Color="Color.Primary" OnClick="NavigateToHome">
    @(IsVerified == null ? "در حال بررسی تراکنش..." : "بازگشت")
</MudButton>