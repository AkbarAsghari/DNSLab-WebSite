@if (_IsSubscipted == null)
{
    <MudProgressCircular Indeterminate Size="Size.Small" />
}
else if (_IsSubscipted == true)
{
    <MudButton OnClick="ShowSubscriptionDetails" EndIcon="@Icons.Material.Filled.WorkspacePremium" IconSize="Size.Large"
           IconColor="Color.Warning" Color="Color.Inherit">جزئیات اشتراک</MudButton>
}
else
{
    <MudButton Href="/Subscriptions/Plans" EndIcon="@Icons.Material.Filled.WorkspacePremium" IconSize="Size.Large"
           IconColor="Color.Warning" Color="Color.Inherit">خرید اشتراک</MudButton>
}


<MudDialog Options="new DialogOptions{CloseButton=true,MaxWidth=MaxWidth.Medium,FullWidth=true}" @bind-IsVisible="_ShowSubscriptionDetails">
    <TitleContent>
        <MudText Typo="Typo.h3">جزئیات اشتراک</MudText>
    </TitleContent>
    <DialogContent>
        @if (Subscriptions != null)
        {
            <MudDataGrid Items="@Subscriptions.OrderByDescending(x => x.End)" Filterable="false"
                     SortMode="@SortMode.None" Groupable="false">
                <Columns>
                    <TemplateColumn Title="پلن">
                        <CellTemplate>
                            <MudText>@context.Item.Plan.Name</MudText>
                        </CellTemplate>
                    </TemplateColumn>
                    <TemplateColumn Title="شروع">
                        <CellTemplate>
                            <MudText>@context.Item.Start.ToLocalizerString()</MudText>
                        </CellTemplate>
                    </TemplateColumn>
                    <TemplateColumn Title="پایان">
                        <CellTemplate>
                            <MudText>@context.Item.End.ToLocalizerString()</MudText>
                        </CellTemplate>
                    </TemplateColumn>
                    <TemplateColumn Title="وضعیت تراکنش">
                        <CellTemplate>
                            @switch (context.Item.TransactionStatus)
                            {
                                case (int)TransactionStatusEnum.PaidConfirmed:
                                    <MudText Color="Color.Success" >موفق</MudText>
                                    break;
                                case (int)TransactionStatusEnum.PaidUnverified:
                                    <MudText Color="Color.Warning">پرداخت شده - تاییدنشده</MudText>
                                    break;
                                case (int)TransactionStatusEnum.CanceledByUser:
                                    <MudText Color="Color.Warning">لغو شده توسط کاربر</MudText>
                                    break;
                                case (int)TransactionStatusEnum.TheCardNumberIsInvalid:
                                    <MudText Color="Color.Warning">شماره کارت نامعتبر می‌باشد</MudText>
                                    break;
                                case (int)TransactionStatusEnum.TheAccountBalanceIsInsufficient:
                                    <MudText Color="Color.Warning">موجودی حساب کافی نمی‌باشد</MudText>
                                    break;
                                case (int)TransactionStatusEnum.TheEnteredPasswordIsWrong:
                                    <MudText Color="Color.Warning">رمز واردشده اشتباه می‌باشد</MudText>
                                    break;
                                case (int)TransactionStatusEnum.TheIssuerOfTheCardIsInvalid:
                                    <MudText Color="Color.Warning">صادرکننده‌ی کارت نامعتبر می‌باشد</MudText>
                                    break;
                                case (int)TransactionStatusEnum.TheCardIsNotAccessible:
                                    <MudText Color="Color.Warning">کارت قابل دسترسی نمی‌باشد</MudText>
                                    break;
                                case (int)TransactionStatusEnum.TheNumberOfRequestsIsOverTheLimit:
                                case (int)TransactionStatusEnum.TheNumberOfOnlinePaymentsPerDayIsMoreThanTheAllowedLimit:
                                case (int)TransactionStatusEnum.TheAmountOfDailyInternetPaymentIsMoreThanTheAllowedLimit:
                                case (int)TransactionStatusEnum.SwitchError:
                                default:
                                    <MudText Color="Color.Warning">خطای نامعلوم</MudText>
                                    break;
                            }
                        </CellTemplate>
                    </TemplateColumn>
                   @* <TemplateColumn Title="@localizer["Target"]">
                        <CellTemplate>
                            <MudText>
                                <MudLink>
                                    @switch ((DNSRecordTypeEnum)context.Item.RecordType)
                                    {
                                        case DNSRecordTypeEnum.A:
                                            @context.Item.IPv4Address
                                            break;
                                        case DNSRecordTypeEnum.AAAA:
                                            @context.Item.IPv6Address
                                            break;
                                        case DNSRecordTypeEnum.CNAME:
                                            @context.Item.HostNameAlias
                                            break;
                                        case DNSRecordTypeEnum.WebRedirect:
                                            @context.Item.URLOrIp.MakeCut(20)
                                            break;
                                    }
                                </MudLink>
                            </MudText>
                        </CellTemplate>
                    </TemplateColumn>
                    <TemplateColumn Title="@localizer["Type"]">
                        <CellTemplate>
                            <MudText>
                                @((DNSRecordTypeEnum)context.Item.RecordType +
                                ((DNSRecordTypeEnum)context.Item.RecordType == DNSRecordTypeEnum.WebRedirect ?
                                " (" + context.Item.RedirectHttpResponseStatusCode + ")" :
                                String.Empty))
                            </MudText>
                        </CellTemplate>
                    </TemplateColumn>
                    <TemplateColumn>
                        <CellTemplate>
                            <MudStack Row>
                            <BaseButtonComponent Caption=@localizer["Edit"] IsBussyCaption=@localizer["Progressing"]
                                                 Color=Color.Warning Icon=@Icons.Material.Filled.Edit
                                                 OnClick=@(()=>EditHostName(context.Item)) />
                            <BaseButtonComponent Caption=@localizer["Delete"] IsBussyCaption=@localizer["Progressing"]
                                                 Color=Color.Error Icon=@Icons.Material.Filled.Delete
                                                 OnClick=@(()=>DeleteHostNameAsync(context.Item)) />
                        </MudStack>
                    </CellTemplate>
                </TemplateColumn>*@
            </Columns>
        </MudDataGrid>
        }
    </DialogContent>
</MudDialog>